{
  "name": "tsuka-ryu-funstack-blog",
  "version": "1.0.0",
  "description": "A static tech blog built with FUNSTACK Static, FUNSTACK Router, and ox-content.",
  "private": true,
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host",
    "start": "vite build && vite preview --host",
    "design": "vite design --config design/vite.config.ts --open",
    "typecheck": "tsgo --noEmit"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": "24.x",
    "pnpm": ">=11.6.0"
  },
  "dependencies": {
    "@fontsource/zen-kaku-gothic-new": "^5.2.7",
    "@funstack/router": "^1.1.1",
    "@funstack/static": "^1.2.0",
    "@ox-content/napi": "^2.70.0",
    "@paper-design/shaders-react": "0.0.76",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shiki": "^4.2.0",
    "temporal-polyfill-lite": "^0.4.0",
    "transliteration": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260612.1",
    "@vitejs/plugin-react": "^6.0.2",
    "takumi-js": "^1.8.3",
    "vite": "^8.0.16"
  }
}
